# Copy this to `.env.local` (gitignored) and fill in your values.
# .env.local holds machine-specific config + secrets and must NOT be committed.

# ── Web supervisor / storage roots ────────────────────────────────────────────
# These values are read by `server-launch.mjs` when you run `npm run dev` / `npm run start`.
# Use them when a user wants Leash data, runtime files, or caches on another disk/volume.

# HTTP bind for the local dashboard.
# PORT=6801
# HOSTNAME=127.0.0.1

# Install-level root. Leash stores device.json, active.json, and per-device scopes under:
#   <LEASH_BASE>/Leash/
# By default each device scope keeps its local workspace inside:
#   <LEASH_BASE>/Leash/<device-id>/data/
# Example for a different drive:
# LEASH_BASE=/Volumes/External/Users/cartel

# Optional explicit root for device-local data. When set, every derived path moves under:
#   <LEASH_DATA_ROOT>/<device-id>/
# That means models live at `<LEASH_DATA_ROOT>/<device-id>/models`, the DB at
# `<LEASH_DATA_ROOT>/<device-id>/db/newsroom.db`, and deleting one device folder clears that
# whole local workspace cleanly.
# LEASH_DATA_ROOT=/Volumes/External/LeashData

# Optional explicit sources used by the supervisor / packaged runtime.
# LEASH_RUNTIME_SRC=/absolute/path/to/leash-standalone
# LEASH_QVAC_CONFIG_SRC=/absolute/path/to/mycelium
# LEASH_DB_TEMPLATE=/absolute/path/to/newsroom-template.db
# LEASH_NODE_BIN=/opt/homebrew/bin/node

# Shared local ports.
# MYCELIUM_SERVE_PORT=11435
# HYPHA_PORT=11437

# ── Home Assistant (optional — smart-home skill) ──────────────────────────────
# A long-lived access token from Home Assistant → Profile → Long-Lived Access Tokens.
LEASH_HA_URL=http://homeassistant.local:8123
LEASH_HA_TOKEN=your-long-lived-access-token

# ── Workspace / computer-use (all optional, portable defaults shown) ──────────
# Where the mcp-installer skill clones repos. By default the app scopes this inside each
# device's `data/.leash-mcp-repos`. Override only if you explicitly want it elsewhere.
# LEASH_MCP_REPOS_DIR=~/.leash-mcp-repos

# run_command's default cwd + jail (the "home" for shell work), and the read-only
# bash file-search root. Both default to your home directory.
# LEASH_COMPUTER_ROOT=~
# LEASH_BASH_ROOT=~

# Slow `yarn/npm install` needs more than the 60s default (ms).
# LEASH_COMMAND_TIMEOUT_MS=240000

# ── Model overrides (optional) ────────────────────────────────────────────────
# QVAC_OPENAI_URL=http://127.0.0.1:11435/v1
# LEASH_CHAT_MODEL=qwen3-4b
