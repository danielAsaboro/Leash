# dependencies
node_modules/

# build output
dist/
*.tsbuildinfo

# QVAC model weight cache (multi-GB GGUF; warmed on first online run)
.qvac/
.cache/
**/model-cache/
*.gguf
*.safetensors

# fine-tune artifacts
checkpoints/
results/
spike/checkpoints/
spike/results/

# run logs / audit JSONL (real excerpts are committed into submission/ instead)
spike/logs/*.jsonl
spike/logs/*.log
logs/*.log
**/logs/*.jsonl
**/logs/*.log

# generated graph node stores (rebuilt from data/notes on each run)
**/data/graph.jsonl
**/data/personal-graph.jsonl

# Week-2 mesh runtime state (per-device; not source)
**/data/mesh-store/
**/data/invite.txt
**/data/embedded-ids.json
# ephemeral corestores created by two-process smokes under their logs/ dir
**/logs/*-store/

# newsroom SQLite db (regenerated from migrations + seed; migrations ARE committed)
**/prisma/*.db
**/prisma/*.db-journal
**/prisma/*.db-wal
**/prisma/*.db-shm

# Next.js (apps/web)
**/.next/
**/next-env.d.ts
**/out/

# diffusion-generated hero images (regenerated by the newsroom pipeline)
apps/web/public/hero/*.png
# on-device TTS read-aloud audio (regenerated by the newsroom pipeline)
apps/web/public/audio/*.wav
# Leash generate_image outputs (regenerated on demand)
apps/web/public/leash-gen/*.png

# Leash runtime data (per-user; regenerated): chat store, dreaming output, photo tags
**/data/leash-chats/
**/data/leash-dreams.json
**/data/leash-photo-tags.json

# os / editor
.DS_Store
*.pcap

# Leash dashboard — per-machine runtime / user state (regenerated; not source)
data/leash-tasks.json
data/leash-memories.json
data/leash-prompts.json
data/leash-tools.json
data/leash-schedule.json
data/leash-activity-tombstones.json
data/leash-cron-state.json
data/leash-cron-runs.jsonl
data/leash-serve.json
data/leash-serve.log
data/leash-models-catalog.json
data/leash-dreams.json
data/leash-downloads/
data/leash-telegram.config.json
data/leash-research/
data/leash-services/
data/leash-skills/

# Leash secret vault (per-machine; key + ciphertext never ship)
data/.leash-key
data/leash-secrets.enc

# Hypha — per-device mesh identity + state (seed, corestore, invite); never ship
data/hypha/
data/hypha-*/

# Machine Economy — per-device wallet secrets (BIP-39 mnemonic, RPC, asset). NEVER ship.
# rsync already excludes data/ between machines; this stops git from ever tracking a key.
data/.economy.env
**/data/.economy.env
data/*.env

# Layer 4 — Memory ("The Understory"): generated training data + adapters (per-machine).
# The FROZEN eval fixtures under data/evolve/eval/ ARE committed (the honesty harness),
# so we ignore evolve's loose JSONL + checkpoints by name, NOT the whole dir (git can't
# re-include a path under a fully-excluded parent). Adapter .gguf weights are already
# covered by the global *.gguf rule; this also drops the per-version manifests/dirs.
**/data/evolve/*.jsonl
**/data/evolve/checkpoints/
**/data/adapters/
data/leash-feedback.jsonl

# Local env files — secrets + machine config. Only *.env.example is committed.
.env
.env.local
**/.env
**/.env.local

# also ignore node_modules symlinks (trailing-slash pattern misses them)
node_modules
apps/mobile/node_modules

logs/